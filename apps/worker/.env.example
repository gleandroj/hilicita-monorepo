REDIS_URL="redis://localhost:6379"
DATABASE_URL="postgresql://user:password@localhost:5432/hilicita"
OPENAI_API_KEY="sk-..."

# When true, send PDF as file to OpenAI (Responses API) instead of parsed text. Overridable per job via usePdfFile.
# USE_PDF_AS_FILE=true

# Model for checklist extraction (default: gpt-4o). Use gpt-4o-mini if hitting 429 TPM limits.
# OPENAI_CHAT_MODEL=gpt-4o

# PDF-as-file: run this many block API calls in parallel (default: 3). Set to 1 for sequential + use delay below if hitting 429.
# PDF_BLOCK_CONCURRENCY=3

# Seconds to wait between PDF-as-file block calls when sequential (PDF_BLOCK_CONCURRENCY=1). Default 0; set to 2 if hitting 429.
# PDF_BLOCK_DELAY_SEC=0

# MinIO (S3-compatible) – optional; when set, unstructured parse result is uploaded as JSON for debugging
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="documents"
